---
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';
const basePath = Astro.site ? new URL(Astro.site).pathname : '/';
---
<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="SportRule：运动官方规则说明与多端导航页面。" />
    <base href={basePath} />
    <title>SportRule</title>
  </head>
  <body>
    <Navbar />
    <main class="container">
      <slot />
    </main>
  </body>
</html>
