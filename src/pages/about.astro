---
import BaseLayout from '../layouts/BaseLayout.astro';
import { sports } from '../data/sports';
import { texts } from '../data/i18n';
const locale = 'zh';
const t = texts[locale];
const title = t.aboutTitle;
---
<BaseLayout lang={locale} currentPath={Astro.url.pathname} pageTitle={title} description={t.homeDescription}>
  <span slot="title">{title}</span>
  <section class="card">
    <h1>{title}</h1>
    <p>{t.aboutIntro}</p>
    <p>{t.aboutSupport}</p>
    <ul>
      {sports.map((sport) => (
        <li key={sport.slug}>{sport.label[locale]}</li>
      ))}
    </ul>
    <p>{t.aboutExtend}</p>
  </section>
</BaseLayout>
