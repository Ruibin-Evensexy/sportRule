---
const basePath = Astro.site ? new URL(Astro.site).pathname : '/';
const navItems = [
  { href: basePath, label: '主页' },
  { href: `${basePath}sports`, label: '运动规则' },
  { href: `${basePath}about`, label: '关于' },
];
---
<nav class="navbar">
  <div class="navbar__brand">SportRule</div>
  <details class="navbar__menu">
    <summary class="navbar__toggle" aria-label="切换导航">☰</summary>
    <ul class="navbar__list">
      {navItems.map((item) => (
        <li class="navbar__item">
          <a class="navbar__link" href={item.href}>{item.label}</a>
        </li>
      ))}
    </ul>
  </details>
</nav>
